# Copy to .env and edit values for your environment (Docker, XAMPP, etc.)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hellforge_db
# If you need to use a socket path (UNIX), set it; on Windows with XAMPP leave empty
DB_SOCKET_PATH=

# Server
SERVER_IP=127.0.0.1
SERVER_PORT=3000
SESSION_SECRET=change_me
